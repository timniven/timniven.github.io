---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Independent research and advisory on AI and information threats.',
} = Astro.props;

const siteTitle = '寒山 / Tim Niven';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/publications/', label: 'Publications' },
  { href: '/advisory/', label: 'Advisory' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Source+Serif+4:opsz,ital,wght@8..60,0,400;8..60,0,500;8..60,0,600;8..60,0,700;8..60,1,400&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #fefefc;
        --bg-alt: #eeece7;
        --fg: #201d1a;
        --muted: #6e6659;
        --accent: #963f3f;
        --border: rgba(32, 29, 26, 0.14);
        --serif: 'Source Serif 4', Georgia, 'Times New Roman', serif;
        --mono: 'IBM Plex Mono', ui-monospace, Menlo, monospace;

        --space-1: 0.25rem;
        --space-2: 0.5rem;
        --space-3: 0.75rem;
        --space-4: 1rem;
        --space-5: 1.5rem;
        --space-6: 2rem;
        --space-7: 3rem;
        --space-8: 4.5rem;

        --content-width: 42rem;
        --page-width: 72rem;
      }

      * { box-sizing: border-box; }

      html { -webkit-text-size-adjust: 100%; }

      body {
        margin: 0;
        font-family: var(--serif);
        font-size: 1.125rem;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.65;
      }

      a { color: var(--accent); text-decoration-thickness: 1px; text-underline-offset: 0.15em; }
      a:hover { text-decoration-thickness: 2px; }

      .shell {
        max-width: var(--page-width);
        margin: 0 auto;
        padding: 0 var(--space-5);
      }

      header.site-header {
        background: var(--bg-alt);
        border-bottom: 1px solid var(--border);
      }

      header.site-header .shell {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: var(--space-3);
        padding-top: var(--space-5);
        padding-bottom: var(--space-5);
      }

      .site-title {
        font-family: var(--serif);
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: var(--fg);
        text-decoration: none;
      }

      nav.site-nav {
        display: flex;
        gap: var(--space-5);
        font-family: var(--serif);
        font-size: 1rem;
      }

      nav.site-nav a {
        color: var(--muted);
        text-decoration: none;
      }

      nav.site-nav a:hover,
      nav.site-nav a[aria-current='page'] {
        color: var(--accent);
      }

      main {
        padding-top: var(--space-8);
        padding-bottom: var(--space-8);
      }

      .page-grid {
        display: grid;
        grid-template-columns: 15rem 1fr;
        gap: var(--space-8);
      }

      .page-main {
        max-width: var(--content-width);
      }

      .identity .headshot {
        width: 100%;
        height: auto;
        border-radius: var(--space-2);
        margin-bottom: var(--space-4);
      }

      .identity .name {
        font-size: 1.4rem;
        font-weight: 600;
        line-height: 1.3;
        margin: 0 0 var(--space-4);
      }

      .identity p {
        margin: 0 0 var(--space-4);
      }

      .identity .links {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
      }

      .identity .links a {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        color: var(--accent);
      }

      .identity .links .icon {
        width: 1rem;
        height: 1rem;
        flex-shrink: 0;
        color: var(--muted);
      }

      .positioning {
        font-size: 1.6rem;
        font-weight: 500;
        line-height: 1.35;
        margin-bottom: var(--space-6);
      }

      @media (max-width: 42rem) {
        .page-grid {
          grid-template-columns: 1fr;
          gap: var(--space-6);
        }
      }

      footer.site-footer {
        background: var(--bg-alt);
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-family: var(--serif);
        font-size: 0.8rem;
      }

      footer.site-footer .shell {
        padding-top: var(--space-5);
        padding-bottom: var(--space-6);
        text-align: center;
      }

      h1, h2, h3, h4 {
        font-family: var(--serif);
        font-weight: 600;
        line-height: 1.25;
        letter-spacing: -0.01em;
      }

      h1 { font-size: 2.25rem; margin: 0 0 var(--space-5); }
      h2 { font-size: 1.5rem; margin: var(--space-7) 0 var(--space-3); }
      h3 { font-size: 1.2rem; margin: var(--space-6) 0 var(--space-3); }

      p { margin: 0 0 var(--space-4); }

      .meta {
        font-family: var(--serif);
        font-size: 0.95rem;
        color: var(--muted);
      }

      blockquote {
        margin: var(--space-5) 0;
        padding-left: var(--space-4);
        border-left: 2px solid var(--accent);
        color: var(--muted);
        font-style: italic;
      }

      pre {
        overflow-x: auto;
        padding: var(--space-4);
        background: rgba(32, 29, 26, 0.05);
        border-radius: 3px;
        font-size: 0.85rem;
      }

      code {
        font-family: var(--mono);
        background: rgba(32, 29, 26, 0.06);
        padding: 0.1em 0.35em;
        border-radius: 3px;
        font-size: 0.9em;
      }

      pre code { background: none; padding: 0; }

      ul, ol { padding-left: 1.3em; margin: 0 0 var(--space-4); }
      li { margin-bottom: var(--space-2); }

      img { max-width: 100%; }

      hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: var(--space-6) 0;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="shell">
        <a class="site-title" href="/">寒山 · Tim Niven, PhD</a>
        <nav class="site-nav">
          {nav.map((item) => (
            <a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <div class="shell">
        <div class="page-grid">
          <aside class="identity">
            <img class="headshot" src="/headshot.jpg" alt="Tim Niven" width="240" height="360" />
            <p class="name">寒山<br />Tim Niven, PhD</p>
            <p class="role meta">AI &amp; information threats researcher and advisor</p>
            <ul class="links meta">
              <li><a href="mailto:tim.niven.public@gmail.com">tim.niven.public@gmail.com</a></li>
              <li>
                <a href="https://github.com/timniven">
                  <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                  <span>GitHub</span>
                </a>
              </li>
              <li>
                <a href="https://www.linkedin.com/in/tim-niven-phd">
                  <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.069-.926-2.069-2.068 0-1.143.925-2.069 2.069-2.069 1.142 0 2.069.926 2.069 2.069 0 1.142-.927 2.068-2.069 2.068zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  <span>LinkedIn</span>
                </a>
              </li>
              <li>
                <a href="https://scholar.google.com/citations?user=B9vqlpwAAAAJ&hl=en">
                  <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.51 14.978 10 12 10c-2.977 0-5.548 1.51-6.758 3.769zM12 10a4.993 4.993 0 00-4.929 5.796c.11.72.35 1.395.701 2.001.762 1.311 1.983 2.325 3.446 2.847.545.194 1.14.335 1.782.335s1.237-.141 1.782-.335c1.463-.522 2.684-1.536 3.446-2.847.351-.606.591-1.281.701-2.001A4.993 4.993 0 0012 10z"/></svg>
                  <span>Google Scholar</span>
                </a>
              </li>
              <li>
                <a href="https://orcid.org/0000-0003-2423-6037">
                  <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z"/></svg>
                  <span>ORCID</span>
                </a>
              </li>
            </ul>
          </aside>
          <div class="page-main">
            <slot />
          </div>
        </div>
      </div>
    </main>
    <footer class="site-footer">
      <div class="shell">
        <p>寒山 · Tim Niven &middot; <a href="mailto:tim.niven.public@gmail.com">tim.niven.public@gmail.com</a></p>
      </div>
    </footer>
  </body>
</html>
