---
interface Props {
  title: string;
}

const { title } = Astro.props;
const siteTitle = 'Tim Niven (寒山)';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | {siteTitle}</title>
    <meta name="description" content="Information and ideas pertaining to my research and other interests." />
    <link rel="icon" href="/favicon.ico" />
    <style>
      :root {
        color-scheme: light dark;
        --max-width: 40rem;
        --fg: #222;
        --bg: #fff;
        --muted: #666;
        --link: #1a5fb4;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #ddd;
          --bg: #181818;
          --muted: #999;
          --link: #7cb0f0;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.6;
      }
      header, main, footer {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1.25rem 1rem;
      }
      header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.5rem;
        border-bottom: 1px solid var(--muted);
      }
      header a { color: var(--fg); text-decoration: none; }
      .site-title { font-weight: 700; font-size: 1.1rem; }
      nav a { margin-left: 1rem; color: var(--muted); }
      nav a:hover { color: var(--link); }
      a { color: var(--link); }
      footer {
        margin-top: 2rem;
        border-top: 1px solid var(--muted);
        color: var(--muted);
        font-size: 0.9rem;
      }
      ul.post-list { list-style: none; padding: 0; }
      ul.post-list li { margin-bottom: 1rem; }
      .post-meta { color: var(--muted); font-size: 0.9rem; }
      pre { overflow-x: auto; padding: 0.75rem; background: rgba(128, 128, 128, 0.1); }
      code { background: rgba(128, 128, 128, 0.1); padding: 0.1rem 0.3rem; }
      pre code { background: none; padding: 0; }
      img { max-width: 100%; }
    </style>
  </head>
  <body>
    <header>
      <a class="site-title" href="/">{siteTitle}</a>
      <nav>
        <a href="/about/">About</a>
        <a href="/publications/">Publications</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>{siteTitle} · <a href="https://github.com/timniven">github.com/timniven</a></p>
    </footer>
  </body>
</html>
